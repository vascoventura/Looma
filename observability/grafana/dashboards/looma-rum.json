{
  "annotations": {
    "list": []
  },
  "description": "Frontend UX proxy for Looma. Uses spanmetrics (server-side) + OTLP logs. True browser RUM needs a JS instrumentor sending to the OTLP endpoint.",
  "editable": true,
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "looma",
    "rum",
    "frontend"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Looma - Real User Monitoring (proxy)",
  "uid": "looma-rum",
  "version": 1,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(traces_span_metrics_calls_total, service_name)",
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "current": {
          "text": "looma-web",
          "value": "looma-web"
        }
      },
      {
        "name": "span",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(traces_span_metrics_calls_total{service_name=~\"$service\"}, span_name)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests ? selected range",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(traces_span_metrics_calls_total{service_name=~\"$service\",span_name=~\"$span\"}[$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 latency (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1000
              },
              {
                "color": "red",
                "value": 2500
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"$service\",span_name=~\"$span\"}[5m])))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors ? selected range",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(traces_span_metrics_calls_total{service_name=~\"$service\",span_name=~\"$span\",status_code=\"STATUS_CODE_ERROR\"}[$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Stack availability (min up)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(up{job=~\"prometheus|otelcol_internal|data-prepper\"})"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=~\"$service\",span_name=~\"$span\"}[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Latency p95 (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"$service\",span_name=~\"$span\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Slowest spans (p95 latency)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "orientation": "vertical",
        "legend": {
          "displayMode": "hidden"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, histogram_quantile(0.95, sum by (span_name, le) (increase(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"$service\",span_name=~\"$span\"}[$__range]))))",
          "legendFormat": "{{span_name}}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "valueLabel": "p95_ms"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent errors (OTLP logs)",
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "opensearch-events"
      },
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "query": "serviceName:\"$service\" AND (severityText:ERROR OR body:*error* OR body:*exception*)",
          "metrics": [
            {
              "type": "logs",
              "id": "1"
            }
          ],
          "bucketAggs": [],
          "timeField": "time"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent backend logs (docker)",
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "opensearch-logs"
      },
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "query": "(index_service:\"$service\" OR service:\"$service\" OR container_name:*${service}*) AND (message:*error* OR message:*warn* OR message:*exception*)",
          "metrics": [
            {
              "type": "logs",
              "id": "1"
            }
          ],
          "bucketAggs": [],
          "timeField": "@timestamp"
        }
      ],
      "options": {
        "showHeader": true
      }
    }
  ]
}
