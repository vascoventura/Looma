{
  "annotations": {
    "list": []
  },
  "description": "Learning performance based on score telemetry (looma_score_ratio), broken down by year (grade), subject and activity.",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "looma",
    "learning",
    "scores"
  ],
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Looma - Learning Scores",
  "uid": "looma-learning-scores",
  "version": 1,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "grade",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(looma_score_ratio, looma_grade)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": ".*"
        }
      },
      {
        "name": "subject",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(looma_score_ratio, looma_subject)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": ".*"
        }
      },
      {
        "name": "activity",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(looma_score_ratio, looma_activity)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Average score (selected)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.75
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(sum_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\"}[$__range])) / clamp_min(sum(count_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\"}[$__range])), 1))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Attempts (selected)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\"}[$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Average score over time - by subject",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum by (looma_subject) (sum_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_subject!=\"\"}[15m])) / clamp_min(sum by (looma_subject) (count_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_subject!=\"\"}[15m])), 1))",
          "legendFormat": "{{looma_subject}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Average score by subject",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "noValue": "no scores in range"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "looma_subject" },
            "properties": [
              { "id": "displayName", "value": "subject" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "avg_score" },
              { "id": "unit", "value": "percentunit" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 },
              { "id": "custom.displayMode", "value": "gradient-gauge" }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "looma_subject": 0, "Value": 1 }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ],
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum by (looma_subject) (sum_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_subject!=\"\"}[$__range])) / clamp_min(sum by (looma_subject) (count_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_subject!=\"\"}[$__range])), 1))",
          "legendFormat": "{{looma_subject}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent score events (OTLP)",
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "opensearch-events"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "query": "serviceName:\"looma-web\" AND (body:*score* OR body:*exam* OR body:*exercise*)",
          "metrics": [
            {
              "type": "logs",
              "id": "1"
            }
          ],
          "bucketAggs": [],
          "timeField": "time"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Attempts by subject",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "noValue": "no attempts in range"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "looma_subject" },
            "properties": [
              { "id": "displayName", "value": "subject" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "attempts" },
              { "id": "unit", "value": "short" },
              { "id": "custom.displayMode", "value": "gradient-gauge" }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "looma_subject": 0, "Value": 1 }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ],
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, sum by (looma_subject) (count_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_subject!=\"\"}[$__range])))",
          "legendFormat": "{{looma_subject}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Average score by grade",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "noValue": "no scores in range"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "looma_grade" },
            "properties": [
              { "id": "displayName", "value": "grade" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "avg_score" },
              { "id": "unit", "value": "percentunit" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 },
              { "id": "custom.displayMode", "value": "gradient-gauge" }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "looma_grade": 0, "Value": 1 }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ],
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum by (looma_grade) (sum_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_grade!=\"\"}[$__range])) / clamp_min(sum by (looma_grade) (count_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_grade!=\"\"}[$__range])), 1))",
          "legendFormat": "{{looma_grade}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Average score by grade & subject",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "noValue": "no scores in range"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "looma_grade" },
            "properties": [
              { "id": "displayName", "value": "grade" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "looma_subject" },
            "properties": [
              { "id": "displayName", "value": "subject" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "avg_score" },
              { "id": "unit", "value": "percentunit" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 },
              { "id": "custom.displayMode", "value": "gradient-gauge" }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "looma_grade": 0, "looma_subject": 1, "Value": 2 }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum by (looma_grade, looma_subject) (sum_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_grade!=\"\", looma_subject!=\"\"}[$__range])) / clamp_min(sum by (looma_grade, looma_subject) (count_over_time(looma_score_ratio{looma_grade=~\"$grade\", looma_subject=~\"$subject\", looma_activity=~\"$activity\", looma_grade!=\"\", looma_subject!=\"\"}[$__range])), 1))",
          "legendFormat": "{{looma_grade}} {{looma_subject}}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
