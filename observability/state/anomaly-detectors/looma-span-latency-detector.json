{
  "name": "looma-span-latency-anomaly",
  "description": "RED/Duration: anomalous avg + max span duration per service. Excludes synthetic topology-probe spans.",
  "time_field": "startTime",
  "indices": [
    "otel-v1-apm-span-*"
  ],
  "category_field": [
    "serviceName.keyword"
  ],
  "filter_query": {
    "bool": {
      "must_not": [
        {
          "term": {
            "span.attributes.looma@topology_probe": true
          }
        }
      ]
    }
  },
  "detection_interval": {
    "period": {
      "interval": 2,
      "unit": "MINUTES"
    }
  },
  "window_delay": {
    "period": {
      "interval": 1,
      "unit": "MINUTES"
    }
  },
  "schema_version": 0,
  "feature_attributes": [
    {
      "feature_name": "avg_duration_nanos",
      "feature_enabled": true,
      "aggregation_query": {
        "avg_duration_nanos": {
          "avg": {
            "field": "durationInNanos"
          }
        }
      }
    },
    {
      "feature_name": "max_duration_nanos",
      "feature_enabled": true,
      "aggregation_query": {
        "max_duration_nanos": {
          "max": {
            "field": "durationInNanos"
          }
        }
      }
    }
  ]
}
