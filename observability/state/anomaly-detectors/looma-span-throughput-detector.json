{
  "name": "looma-span-throughput-anomaly",
  "description": "RED/Rate: anomalous request throughput per service (spike = load; drop = a service became unreachable/degraded). Excludes synthetic topology-probe spans.",
  "time_field": "startTime",
  "indices": [
    "otel-v1-apm-span-*"
  ],
  "category_field": [
    "serviceName.keyword"
  ],
  "filter_query": {
    "bool": {
      "must_not": [
        {
          "term": {
            "span.attributes.looma@topology_probe": true
          }
        }
      ]
    }
  },
  "detection_interval": {
    "period": {
      "interval": 2,
      "unit": "MINUTES"
    }
  },
  "window_delay": {
    "period": {
      "interval": 1,
      "unit": "MINUTES"
    }
  },
  "schema_version": 0,
  "feature_attributes": [
    {
      "feature_name": "request_count",
      "feature_enabled": true,
      "aggregation_query": {
        "request_count": {
          "value_count": {
            "field": "durationInNanos"
          }
        }
      }
    }
  ]
}
